// Secrets.sample.xcconfig — copy to `Secrets.xcconfig` (which is .gitignored)
// and fill in your local development keys. Defaults.xcconfig consumes this
// file via `#include?` so a missing file is silently OK.
//
// DO NOT commit the real `Secrets.xcconfig`. Production builds get values
// from the Codemagic encrypted variable group instead.

// Anthropic Claude API — required to enable the live AI coach. Without it
// the app silently falls back to MockAICoachService.
// Get a key: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY = sk-ant-api03-...

// Optional model override (defaults to claude-sonnet-4-6).
CLAUDE_MODEL = claude-sonnet-4-6

// FatSecret (optional, premier-tier barcode coverage).
// Apply: https://platform.fatsecret.com/api/Default.aspx?screen=rapip
FATSECRET_CLIENT_ID =
FATSECRET_CLIENT_SECRET =

// USDA FoodData Central (optional, US food coverage).
// Sign up: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY =
